# Copy this file to .env and fill in your own key.
# Get a free Gemini API key at https://aistudio.google.com/apikey
GEMINI_API_KEY=your-key-here

# Optional: override which Gemini model is used
# (defaults to "gemini-flash-latest", Google's auto-updating alias for their
# current Flash model -- pin a specific version here if you need stability
# across Google's model deprecations, e.g. GEMINI_MODEL=gemini-3.5-flash)
# GEMINI_MODEL=gemini-flash-latest
